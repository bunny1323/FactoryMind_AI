# ─── Vector DB ──────────────────────────────────────────────────────────────────
VECTOR_BACKEND=qdrant
QDRANT_URL=https://<your-cluster-url>.qdrant.tech:6333
QDRANT_API_KEY=<your-qdrant-api-key>

# ─── Embeddings ──────────────────────────────────────────────────────────────────
EMBEDDING_BACKEND=fastembed
SPARSE_EMBEDDING_BACKEND=fastembed
RERANKER_BACKEND=cross_encoder
RERANKER_MODEL=BAAI/bge-reranker-base

# ─── LLM Provider ────────────────────────────────────────────────────────────────
# Options: mock | groq | openai | openai_compatible | ollama | anthropic
LLM_PROVIDER=groq

# --- Option 1: Groq (free tier — may be blocked by Cloudflare in some regions)
GROQ_API_KEY=<your-groq-api-key>
GROQ_MODEL=llama-3.3-70b-versatile

# --- Option 2: Google AI Studio (free, OpenAI-compatible, no Cloudflare issues)
# Get key at: https://aistudio.google.com/apikey
# LLM_PROVIDER=openai_compatible
# OPENAI_API_KEY=<your-google-ai-studio-api-key>
# OPENAI_MODEL=gemini-2.0-flash
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# --- Option 3: OpenRouter (free models available, no Cloudflare issues)
# Get key at: https://openrouter.ai/keys
# LLM_PROVIDER=openai_compatible
# OPENAI_API_KEY=<your-openrouter-api-key>
# OPENAI_MODEL=meta-llama/llama-3.1-8b-instruct:free
# OPENAI_BASE_URL=https://openrouter.ai/api/v1

# --- Option 4: Local Ollama (no API key, fully offline)
# Install: https://ollama.ai  then: ollama pull qwen2.5:7b
# LLM_PROVIDER=ollama
# OLLAMA_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
